{
  "name": "steam-games-mcp",
  "version": "0.10.1",
  "mcpName": "io.github.Grinv/steam-games-mcp",
  "description": "Enables LLMs to search and evaluate Steam games — prices, discounts, reviews and Steam Deck compatibility with no API key, plus a player's library, achievements and friends via the official Steam Web API.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Grinv",
    "email": "4070730+Grinv@users.noreply.github.com",
    "url": "https://github.com/Grinv"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "steam",
    "steamworks",
    "games"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Grinv/steam-games-mcp.git"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "steam-games-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && tsup",
    "build:tests": "node scripts/build-tests.mjs",
    "test": "npm run build:tests && node scripts/run-tests.mjs",
    "test:coverage": "npm run build:tests && node scripts/run-tests.mjs --coverage",
    "version": "node scripts/sync-version.mjs && git add src/version.ts manifest.json server.json",
    "lint": "eslint .",
    "check:api": "node scripts/check-api.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "node dist/index.js",
    "inspector": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "2.0.0-beta.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "2.1.2",
    "@modelcontextprotocol/client": "2.0.0-beta.4",
    "@modelcontextprotocol/codemod": "2.0.0-beta.4",
    "@modelcontextprotocol/core": "2.0.0-beta.4",
    "@eslint/js": "10.0.1",
    "@types/node": "^26.1.1",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "^3.9.4",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true
  }
}
